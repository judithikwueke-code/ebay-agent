# ── eBay Developer App ──────────────────────────────────────────────────────
# Get these from developer.ebay.com → My Account → Application Keys
EBAY_APP_ID=your_app_id_here
EBAY_CERT_ID=your_cert_id_here
EBAY_DEV_ID=your_dev_id_here

# OAuth user token for YOUR seller account
# Generate at: developer.ebay.com → User Tokens → Get a User Token
EBAY_USER_TOKEN=your_ebay_oauth_user_token_here

# ── Claude API ───────────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Avasam (UK's largest dropship aggregator) ────────────────────────────────
# Register at: avasam.co.uk → apply for API access
AVASAM_API_KEY=

# ── Costway UK (UK warehouse — furniture, fitness, home) ─────────────────────
# Apply for trade account at: costway.co.uk/trade
COSTWAY_API_KEY=

# ── BigBuy (EU + UK — fallback supplier) ─────────────────────────────────────
# Register at: bigbuy.eu → API access requires a paid wholesale account
BIGBUY_API_KEY=

# ── CJ Dropshipping (global fallback) ────────────────────────────────────────
# Register at: app.cjdropshipping.com → Account → API
CJ_API_KEY=

# ── Wholesale2B (optional — has native eBay sync) ────────────────────────────
WHOLESALE2B_API_KEY=

# ── Email alerts ─────────────────────────────────────────────────────────────
ALERT_EMAIL=07487863927n@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Use a Gmail App Password (not your main password)
# Generate at: myaccount.google.com → Security → App Passwords
SMTP_PASS=your_app_password

# ── Agent behaviour ──────────────────────────────────────────────────────────
# Start low; raise manually as your account gains trust
DAILY_LISTING_CAP=10

# Path to SQLite database file
DB_PATH=ebay_agent.db
